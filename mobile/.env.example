# Jonno Environment Variables
# Copy this file to .env and fill in your values

# Supabase (database and auth)
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# API Base URL
EXPO_PUBLIC_API_BASE_URL=https://jonnoai.com

# Anthropic Claude API (AI meal generation + food scan)
# Set in the Next.js server .env, not here — mobile calls through /api/agent/chat

# RapidAPI (Woolworths/Coles product search)
EXPO_PUBLIC_RAPIDAPI_KEY=

# Google Places API (nearby store finder)
EXPO_PUBLIC_GOOGLE_PLACES_API_KEY=

# Hevy API (strength training — coming soon)
EXPO_PUBLIC_HEVY_API_KEY=
