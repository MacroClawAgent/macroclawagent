{
  "expo": {
    "name": "Jonno",
    "slug": "jonno",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "jonno",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0066EE"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.jonnoai.app",
      "infoPlist": {
        "NSHealthShareUsageDescription": "MacroClaw reads your workouts and activity data to personalise your nutrition recommendations.",
        "NSHealthUpdateUsageDescription": "MacroClaw may write nutrition data to Apple Health to keep your health records in sync."
      }
    },
    "android": {
      "package": "com.jonnoai.app",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Jonno uses your location to find the nearest Woolworths and Coles supermarket for your grocery order."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {}
  }
}
